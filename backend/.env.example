# NormativaUP - Variables de entorno
# Copia este archivo como .env y configura tus claves

# OpenAI (Requerido)
OPENAI_API_KEY=sk-tu-api-key-aqui

# Embedding provider: "openai" (cloud, low memory) or "local" (sentence-transformers, high memory)
EMBEDDING_PROVIDER=openai

# Servidor
HOST=0.0.0.0
PORT=8000